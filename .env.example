# Schema Registry upstream
UPSTREAM_URL=https://psrc-xxxxxxx.region.aws.confluent.cloud
UPSTREAM_API_KEY=
UPSTREAM_API_SECRET=
UPSTREAM_TIMEOUT=10s

# Redis / Valkey
REDIS_ADDR=localhost:6379
REDIS_USERNAME=                  # optional, for Redis 6+ ACLs
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=50

# Optional TLS to Redis/Valkey (managed services typically expose TLS endpoints).
REDIS_TLS=false                  # set to true to enable TLS
REDIS_TLS_CA_FILE=               # optional PEM bundle to verify the server cert
REDIS_TLS_SKIP_VERIFY=false      # dev only — disables cert verification

# Cache TTLs
LATEST_TTL=30s
LIST_TTL=10s

# Server
LISTEN_ADDR=:8080
LOG_LEVEL=info

# Circuit breaker
BREAKER_OPEN_DURATION=10s
BREAKER_FAIL_THRESHOLD=3

# Client identity (only meaningful when proxy is behind an Ingress that
# terminates mTLS and forwards the verified CN as a header). The proxy itself
# does NOT verify the cert — the Ingress does.
CLIENT_CN_HEADER=X-Client-CN
CLIENT_CN_REQUIRED=false
CLIENT_CN_ALLOWLIST=
LABEL_METRICS_BY_CN=false
AUDIT_LOG=true
